---
import Layout from "../layouts/Layout.astro";
import { NOW, type NowItem } from "../data/now";

function splitAroundLink(item: NowItem): [string, string] {
    if (!item.linkLabel) return [item.text, ""];
    const idx = item.text.indexOf(item.linkLabel);
    if (idx === -1) return [item.text, ""];
    return [item.text.slice(0, idx), item.text.slice(idx + item.linkLabel.length)];
}
---

<Layout
    title="now - tom titcombe"
    description="What I'm currently working on, reading, and thinking about."
>
    <div style="margin-bottom: 2rem;">
        <div style="font-size: 11px; color: #555555; margin-bottom: 0.5rem;">
            <a href="/" style="color: #555555; text-decoration: none;">~/</a>
            <span style="color: #00ff41;"> now.txt</span>
        </div>
        <div
            style="display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap;"
        >
            <h1
                style="font-size: 1.6rem; font-weight: 700; color: #00ff41; margin: 0;"
            >
                cat now.txt
            </h1>
            <span style="color: #555555; font-size: 12px;"
                >last updated: {NOW.lastUpdated}</span
            >
        </div>
    </div>

    <div
        style="border: 1px solid rgba(0,255,65,0.15); border-radius: 4px; overflow: hidden; font-size: 13px;"
    >
        <!-- File bar -->
        <div
            style="background: #0d0d0d; border-bottom: 1px solid rgba(0,255,65,0.1); padding: 8px 16px; font-size: 12px; color: #555555;"
        >
            now.txt - readonly - last modified {NOW.lastUpdated}
        </div>

        <div
            style="padding: 2rem; display: flex; flex-direction: column; gap: 2rem;"
        >
            <!-- Building -->
            <div>
                <div
                    style="color: #ffb000; font-size: 12px; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.08em;"
                >
                    # building
                </div>
                <ul
                    style="color: #aacc99; margin: 0; padding-left: 1.5rem; line-height: 1.9; list-style: none;"
                >
                    {
                        NOW.building.map((item) => {
                            const [pre, post] = splitAroundLink(item);
                            return (
                                <li style="position: relative;">
                                    <span
                                        style="color: #00ff41; position: absolute; left: -1.2rem;"
                                    >
                                        ▸
                                    </span>
                                    {item.linkLabel ? (
                                        <>
                                            {pre}
                                            <a
                                                href={item.linkHref}
                                                style="color: #00ff41;"
                                            >
                                                {item.linkLabel}
                                            </a>
                                            {post}
                                        </>
                                    ) : (
                                        item.text
                                    )}
                                </li>
                            );
                        })
                    }
                </ul>
            </div>

            <!-- Reading -->
            <div>
                <div
                    style="color: #ffb000; font-size: 12px; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.08em;"
                >
                    # reading
                </div>
                <ul
                    style="color: #aacc99; margin: 0; padding-left: 1.5rem; line-height: 1.9; list-style: none;"
                >
                    {
                        NOW.reading.map((item) => {
                            const [pre, post] = splitAroundLink(item);
                            return (
                                <li style="position: relative;">
                                    <span
                                        style="color: #555555; position: absolute; left: -1.2rem;"
                                    >
                                        //
                                    </span>
                                    {item.linkLabel ? (
                                        <>
                                            {pre}
                                            <a
                                                href={item.linkHref}
                                                rel="noopener noreferrer"
                                                target="_blank"
                                                style="color: #00ff41;"
                                            >
                                                <em>{item.linkLabel}</em>
                                            </a>
                                            {post}
                                        </>
                                    ) : (
                                        item.text
                                    )}
                                </li>
                            );
                        })
                    }
                </ul>
            </div>

            <!-- Thinking about -->
            <div>
                <div
                    style="color: #ffb000; font-size: 12px; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.08em;"
                >
                    # thinking about
                </div>
                <ul
                    style="color: #aacc99; margin: 0; padding-left: 1.5rem; line-height: 1.9; list-style: none;"
                >
                    {
                        NOW.thinkingAbout.map((item) => (
                            <li style="position: relative;">
                                <span
                                    style="color: #555555; position: absolute; left: -1.2rem;"
                                >
                                    //
                                </span>
                                {item.text}
                            </li>
                        ))
                    }
                </ul>
            </div>

            <!-- Status -->
            <div>
                <div
                    style="color: #ffb000; font-size: 12px; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.08em;"
                >
                    # status
                </div>
                <div style="color: #aacc99; line-height: 1.8;">
                    {NOW.status}
                </div>
            </div>

            <!-- Footer -->
            <div
                style="border-top: 1px solid rgba(0,255,65,0.1); padding-top: 1rem; font-size: 12px; color: #333333; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px;"
            >
                <span>EOF</span>
            </div>
        </div>
    </div>
</Layout>
